import mensajeros.*

describe "Test de roberto y Neo" {

  test "Roberto peso 90 y puede llevar un paquete que esta pago en un caion que tiene acoplado" {
    paquete.serPagado()
    roberto.cambiaTransporte(camion)
    assert.that(roberto.puedeLlevarPaquete(puenteBroklyn))
  }

  test "Neo no puede llevar un paquete que no está pago a la matrix." {
    assert.notThat(neo.puedeLlevarPaquete(laMatrix))
  }

}